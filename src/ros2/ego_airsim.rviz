      Size (m): 0.20000000298023224
      Style: Boxes
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /grid_map/occupancy
      Use Fixed Frame: true
      Use rainbow: true
      Value: false
